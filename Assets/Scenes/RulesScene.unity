  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Cycle of Life (Conway's Game of Life)\n\nVersion: 0.7.3 Beta\n\nNew Features:\n-
    You can open Internet Explorer. There is a blog website you can visit.\n- Desktop
    is more functional. You can open some apps in window with shortcuts.\n- Taskbar
    is dynamic. \n- Solitaire game added. (Buggy version, it will be fixed.)\n- Solitaire
    Themes added. You can change back of the card in the game settings.\n- More functional
    desktop.\n- Double click to open games.\n- Minesweeper game added.\n- 3 difficulty
    selection in Minesweeper\n- You can create or kill cells while simulation is
    playing.\n- You need to enable it in the game screen.\n- Drag your mouse while
    holding Ctrl and left mouse button to create new cells. \n- Drag your mouse while
    holding Ctrl and right mouse button to kill alive cells. \n- Now you can edit
    this update notes. (It deletes when you exit the game)\n\nRules:\n-Birth Rule:
    An empty, or \u201Cdead,\u201D cell with precisely three \u201Clive\u201D neighbors
    (full cells) becomes live.\n\n-Death Rule: A live cell with zero or one neighbors
    dies of isolation; a live cell with four or more neighbors dies of overcrowding.\n\n-Survival
    Rule: A live cell with two or three neighbors remains alive.\n\n\n\n\t\t\t\t\t\t\t  
    synthesizer - ibrahim emre bas\n--------\u200B"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: a026544f366ba7e4d87cdea1457d5ee9, type: 2}
